{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "lib": ["ES2022", "dom"],
    "allowJs": true,
   "paths": {
      "@componentry-ui/angular": ["../../packages/angular/dist"]
    }
  },
  "angularCompilerOptions": {
    "compilationMode": "partial"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}