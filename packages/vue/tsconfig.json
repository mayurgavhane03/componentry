{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "rootDir": "src",
    "declarationDir": "dist/types",
    "outDir": "dist",
    "lib": ["ES2020", "dom"],
    "paths": {
      "@componentry/stencil/*": ["../stencil-core/dist/components/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}