{
  "name": "@componentry/theme",
  "version": "0.0.1",
  "description": "Theme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./layouts": {
      "types": "./dist/layouts/index.d.ts",
      "import": "./dist/layouts/index.js",
      "require": "./dist/layouts/index.cjs"
    },
    "./styles/light.css": "./dist/styles/light.css",
    "./styles/dark.css": "./dist/styles/dark.css",
    "./styles.css": "./dist/styles/index.css",
    "./styles/*": "./dist/styles/*"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "sideEffects": [
    "*.css",
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup && node scripts/copy-css.mjs",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "typescript",
    "utility",
    "css"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "eslint": "^9.15.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.15.0",
    "vitest": "^4.1.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
